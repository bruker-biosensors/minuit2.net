<Project>

  <PropertyGroup>
    <RepoPath>$(MSBuildThisFileDirectory)..</RepoPath>
    <CmakeBuildDir>$(RepoPath)/minuit2.wrap/build/$(Platform)</CmakeBuildDir>
    <SwigOutputPath>$(RepoPath)/minuit2.net/obj/swig</SwigOutputPath>
  </PropertyGroup>

  <Import Project="$(MSBuildThisFileDirectory)NativeCode.targets" />
  <Import Project="$(MSBuildThisFileDirectory)Windows.$(BuildToolchain).targets" />

  <Target Name="CleanBuildDirectories" 
          BeforeTargets="Clean">
    <RemoveDir Directories="$(CmakeBuildDir);$(SwigOutputPath)"/>
  </Target>

  <Target Name="CreateBuildDirectories" 
          BeforeTargets="BeforeBuild">
    <MakeDir Directories="$(CmakeBuildDir);$(SwigOutputPath)"/>
  </Target>

  <!-- Run CMake Configure -->
  <Target Name="CmakeConfigure" 
          BeforeTargets="BeforeBuild" 
          DependsOnTargets="CreateBuildDirectories">
    <PropertyGroup>
      <CmakeBuildCommand>cmake -S $(RepoPath) -B $(CmakeBuildDir) $(CmakeSwigExecutableFlag) $(CmakeBuildToolchainFlags) -DMINUIT2NET_PATH=$(SwigOutputPath) -DROOT_PATH=$(RootClonePath) -Dminuit2_omp=$(UseOpenMP) -Dtarget_name=$(NativeAssemblyName)</CmakeBuildCommand>
    </PropertyGroup>

    <Exec Command="$(CmakeBuildCommand)"
          WorkingDirectory="$(RepoPath)"
          IgnoreExitCode="false"/>
  </Target>

  <!-- Build C++ Library and Generate SWIG Wrappers -->
  <Target Name="BuildNativeDependencies" 
          BeforeTargets="BeforeBuild" 
          DependsOnTargets="CmakeConfigure">
    <PropertyGroup>
      <CmakeBuildCommand>cmake --build "$(CmakeBuildDir)" --config Release</CmakeBuildCommand>
    </PropertyGroup>

    <Exec Command="$(CmakeBuildCommand)"
          WorkingDirectory="$(RepoPath)"/>
  </Target>

  <Target Name="IncludeGeneratedCSharpFiles" 
          AfterTargets="BuildNativeDependencies" 
          BeforeTargets="BeforeCompile">
    <ItemGroup>
      <GeneratedCSharpFiles Include="$(SwigOutputPath)/*.cs"/>
      <Compile Include="@(GeneratedCSharpFiles)"/>
    </ItemGroup>
    <Message Text="Included SWIG generated files from: $(SwigOutputPath)" 
             Importance="high"/>
  </Target>

  <Target Name="CopyNativeBinaries" 
          AfterTargets="BuildNativeDependencies">
    <ItemGroup>
      <NativeBinaries Include="$(CmakeOutputPath)/$(NativeAssemblyName)$(NativeAssemblyExtension)"/>
      <None Include="@(NativeBinaries)" 
            Visible="false" 
            CopyToOutputDirectory="PreserveNewest" 
            CopyToPublishDirectory="PreserveNewest"/>
    </ItemGroup>
  </Target>

  <Target Name="RenameROOTLicense" 
          AfterTargets="CopyNativeBinariesForNuGet">
    <Copy SourceFiles="$(RootClonePath)/LICENSE"
          DestinationFiles="$(IntermediateOutputPath)/ROOT-LICENSE"/>
  </Target>

  <Target Name="AddROOTLicenseToNuget" 
          AfterTargets="CopyNativeBinariesForNuGet; RenameROOTLicense">
    <ItemGroup>
      <None Include="$(IntermediateOutputPath)/ROOT-LICENSE"
            Pack="true"
            PackagePath="third-party-licenses/"/>
      <None Include="$(RootClonePath)/LGPL2_1.txt"
            Pack="true"
            PackagePath="third-party-licenses/"/>
    </ItemGroup>
  </Target>

</Project>
